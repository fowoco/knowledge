{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fowoco.local/schemas/workflow-catalog.schema.json",
  "title": "FOWOCO Workflow Catalog",
  "type": "object",
  "required": ["version", "policy", "workflows"],
  "properties": {
    "version": { "type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$" },
    "policy": { "type": "object" },
    "workflows": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "intent",
          "domains",
          "sensitivity",
          "supported_input_modes",
          "triggers",
          "required_slots_ref",
          "source_ids",
          "steps",
          "completion_evidence"
        ],
        "properties": {
          "id": { "type": "string", "pattern": "^WF-[A-Z]{3}-[0-9]{3}$" },
          "name": { "type": "string", "minLength": 2 },
          "intent": { "type": "string" },
          "domains": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" },
            "uniqueItems": true
          },
          "sensitivity": { "enum": ["low", "medium", "high", "critical"] },
          "supported_input_modes": {
            "type": "array",
            "minItems": 1,
            "items": { "enum": ["WORKER_MESSAGE", "AGENT_TASK", "INTERNAL_REQUEST"] },
            "uniqueItems": true
          },
          "triggers": { "type": "array", "minItems": 1 },
          "required_slots_ref": { "type": "string" },
          "source_ids": {
            "type": "array",
            "items": { "type": "string", "pattern": "^SRC-" },
            "uniqueItems": true
          },
          "checklist_id": { "type": "string", "pattern": "^CHK-" },
          "steps": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["id", "actor", "action", "output"],
              "properties": {
                "id": { "type": "string", "pattern": "^[a-z][a-z0-9_]+$" },
                "actor": { "type": "string" },
                "action": { "type": "string", "minLength": 5 },
                "output": { "type": "string" },
                "gate": { "type": "string" }
              },
              "additionalProperties": false
            }
          },
          "completion_evidence": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string" }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
