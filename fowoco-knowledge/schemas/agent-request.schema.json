{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fowoco.local/schemas/agent-request.schema.json",
  "title": "FOWOCO classified request",
  "type": "object",
  "required": ["request_id", "input_mode", "utterance", "workflow_id", "slots"],
  "properties": {
    "request_id": { "type": "string", "minLength": 1 },
    "reference_at": { "type": "string", "format": "date-time" },
    "input_mode": { "enum": ["WORKER_MESSAGE", "AGENT_TASK", "INTERNAL_REQUEST"] },
    "utterance": { "type": "string", "minLength": 1 },
    "workflow_id": { "type": "string", "pattern": "^WF-[A-Z]{3}-[0-9]{3}$" },
    "intent_candidates": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["intent", "confidence"],
        "properties": {
          "intent": { "type": "string" },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "domains": {
      "type": "array",
      "items": { "type": "string" },
      "uniqueItems": true
    },
    "slots": { "type": "object" }
  },
  "additionalProperties": false
}
